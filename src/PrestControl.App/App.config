<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <connectionStrings>
    <!--
      SOLO DEV. En la máquina del cliente esta cadena se ajusta durante la
      instalación (usuario dedicado con contraseña propia, nunca root).
      La pantalla de Configuración permitirá editarla (Fase 6).
    -->
    <add name="PrestControlDb"
         connectionString="Server=localhost;Port=3306;Database=prestcontrol_db;Uid=root;Pwd=root;" />
  </connectionStrings>
</configuration>
