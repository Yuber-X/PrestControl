<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <connectionStrings>
    <!--
      Reemplazar CAMBIAR_USUARIO y CAMBIAR_PASSWORD con las credenciales
      locales de MySQL. En la máquina del cliente esta cadena se ajusta
      durante la instalación (usuario dedicado, nunca root) y puede
      editarse desde la pantalla de Configuración.
    -->
    <add name="PrestControlDb"
         connectionString="Server=localhost;Port=3306;Database=prestcontrol_db;Uid=CAMBIAR_USUARIO;Pwd=CAMBIAR_PASSWORD;" />
  </connectionStrings>
</configuration>
