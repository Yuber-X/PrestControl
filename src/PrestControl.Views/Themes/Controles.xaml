<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:m="clr-namespace:PrestControl.Models;assembly=PrestControl.Models">

  <!-- ============================================================
       Botones — DESIGN.md §8: radius 8, altura 40, hover -8% luz
       ============================================================ -->
  <Style x:Key="Boton.Primario" TargetType="Button">
    <Setter Property="Background" Value="{DynamicResource Brush.Primario}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontFamily" Value="{StaticResource Fuente.Interfaz}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Height" Value="40" />
    <Setter Property="Padding" Value="16,0" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Fondo"
                  Background="{TemplateBinding Background}"
                  CornerRadius="8"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Fondo" Property="Background" Value="{DynamicResource Brush.PrimarioHover}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Fondo" Property="Background" Value="{DynamicResource Brush.BordeSutil}" />
              <Setter Property="Foreground" Value="{DynamicResource Brush.TextoDeshabilitado}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="Boton.Destructivo" TargetType="Button" BasedOn="{StaticResource Boton.Primario}">
    <Setter Property="Background" Value="{DynamicResource Brush.Destructivo}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Fondo"
                  Background="{TemplateBinding Background}"
                  CornerRadius="8"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Fondo" Property="Background" Value="#B91C1C" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Fondo" Property="Background" Value="{DynamicResource Brush.BordeSutil}" />
              <Setter Property="Foreground" Value="{DynamicResource Brush.TextoDeshabilitado}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Terciario: solo texto indigo, para acciones dentro de tablas -->
  <Style x:Key="Boton.Terciario" TargetType="Button">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Primario}" />
    <Setter Property="FontFamily" Value="{StaticResource Fuente.Interfaz}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Padding" Value="8,4" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Fondo" Background="Transparent" CornerRadius="6"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Fondo" Property="Background" Value="{DynamicResource Brush.PrimarioSutil}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="Boton.Secundario" TargetType="Button" BasedOn="{StaticResource Boton.Primario}">
    <Setter Property="Background" Value="White" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Primario}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Fondo"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{DynamicResource Brush.Primario}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Fondo" Property="Background" Value="{DynamicResource Brush.PrimarioSutil}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ============================================================
       Inputs — altura 40, borde #D4D4D3, focus indigo
       ============================================================ -->
  <Style x:Key="Input.Texto" TargetType="TextBox">
    <Setter Property="Height" Value="40" />
    <Setter Property="Padding" Value="10,0" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="FontFamily" Value="{StaticResource Fuente.Interfaz}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextoPrincipal}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.BordeEstandar}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Border x:Name="Borde"
                  Background="White"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="8">
            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                          VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="Borde" Property="BorderBrush" Value="{DynamicResource Brush.Primario}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="Input.Password" TargetType="PasswordBox">
    <Setter Property="Height" Value="40" />
    <Setter Property="Padding" Value="10,0" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="FontFamily" Value="{StaticResource Fuente.Interfaz}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.BordeEstandar}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="PasswordBox">
          <Border x:Name="Borde"
                  Background="White"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="8">
            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                          VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="Borde" Property="BorderBrush" Value="{DynamicResource Brush.Primario}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Label arriba del input, nunca al lado -->
  <Style x:Key="Input.Label" TargetType="TextBlock" BasedOn="{StaticResource Texto.Cuerpo}">
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextoSecundario}" />
    <Setter Property="Margin" Value="0,0,0,6" />
  </Style>

  <!-- ============================================================
       Card — fondo blanco, borde sutil 0.5, radius 12, sombra nivel 1
       ============================================================ -->
  <Style x:Key="Card" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource Brush.FondoCard}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.BordeSutil}" />
    <Setter Property="BorderThickness" Value="0.5" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="20" />
    <Setter Property="Effect">
      <Setter.Value>
        <DropShadowEffect BlurRadius="2" ShadowDepth="1" Opacity="0.05" Color="Black" />
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ComboBox implícito: texto centrado verticalmente en toda la app -->
  <Style TargetType="ComboBox">
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="FontFamily" Value="{StaticResource Fuente.Interfaz}" />
    <Setter Property="Padding" Value="10,0" />
  </Style>

  <!-- ============================================================
       ScrollBars delgados (6px) para TODA la app: discretos pero
       funcionales — pedido de Yuber 2026-07-10 (punto 4)
       ============================================================ -->
  <Style x:Key="Scroll.Pagina" TargetType="RepeatButton">
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RepeatButton">
          <Border Background="Transparent" />
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="Scroll.Pulgar" TargetType="Thumb">
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Thumb">
          <Border x:Name="Fondo" Background="{DynamicResource Brush.BordeEstandar}"
                  CornerRadius="3" />
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Fondo" Property="Background"
                      Value="{DynamicResource Brush.TextoTerciario}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Implícito: aplica a todos los ScrollViewer (formularios, tablas, combos) -->
  <Style TargetType="ScrollBar">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Width" Value="6" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ScrollBar">
          <Grid Background="Transparent">
            <Track x:Name="PART_Track" IsDirectionReversed="True">
              <Track.DecreaseRepeatButton>
                <RepeatButton Style="{StaticResource Scroll.Pagina}"
                              Command="ScrollBar.PageUpCommand" />
              </Track.DecreaseRepeatButton>
              <Track.Thumb>
                <Thumb Style="{StaticResource Scroll.Pulgar}" />
              </Track.Thumb>
              <Track.IncreaseRepeatButton>
                <RepeatButton Style="{StaticResource Scroll.Pagina}"
                              Command="ScrollBar.PageDownCommand" />
              </Track.IncreaseRepeatButton>
            </Track>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="Orientation" Value="Horizontal">
        <Setter Property="Width" Value="Auto" />
        <Setter Property="Height" Value="6" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ScrollBar">
              <Grid Background="Transparent">
                <Track x:Name="PART_Track" IsDirectionReversed="False">
                  <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{StaticResource Scroll.Pagina}"
                                  Command="ScrollBar.PageLeftCommand" />
                  </Track.DecreaseRepeatButton>
                  <Track.Thumb>
                    <Thumb Style="{StaticResource Scroll.Pulgar}" />
                  </Track.Thumb>
                  <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource Scroll.Pagina}"
                                  Command="ScrollBar.PageRightCommand" />
                  </Track.IncreaseRepeatButton>
                </Track>
              </Grid>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- ============================================================
       Navegación del sidebar (RadioButton para exclusión mutua)
       ============================================================ -->
  <Style x:Key="Sidebar.Item" TargetType="RadioButton">
    <Setter Property="Height" Value="40" />
    <Setter Property="Margin" Value="12,2" />
    <Setter Property="FontFamily" Value="{StaticResource Fuente.Interfaz}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextoSecundario}" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RadioButton">
          <Border x:Name="Fondo" Background="Transparent" CornerRadius="8" Padding="12,0">
            <!-- Ícono opcional en Tag (glifo Segoe MDL2 Assets, nativo de Windows) -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock Text="{TemplateBinding Tag}" FontFamily="Segoe MDL2 Assets"
                         FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0" />
              <ContentPresenter VerticalAlignment="Center" />
            </StackPanel>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Fondo" Property="Background" Value="{DynamicResource Brush.FondoApp}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Fondo" Property="Background" Value="{DynamicResource Brush.PrimarioSutil}" />
              <Setter Property="Foreground" Value="{DynamicResource Brush.Primario}" />
              <Setter Property="FontWeight" Value="Medium" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ============================================================
       Tablas — DESIGN.md §8: header #F4F4F2 uppercase, filas 44px,
       border-bottom 0.5, hover #FAFAF9, selección indigo 50, sin zebra
       ============================================================ -->
  <Style x:Key="Tabla.Encabezado" TargetType="DataGridColumnHeader">
    <Setter Property="Background" Value="{DynamicResource Brush.FondoEncabezadoTabla}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextoSecundario}" />
    <Setter Property="FontFamily" Value="{StaticResource Fuente.Interfaz}" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Typography.Capitals" Value="AllSmallCaps" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
  </Style>

  <!-- Variante alineada a la izquierda: columnas de texto largo
       (Estado, Nombre, Cliente) — pedido de Yuber 2026-07-10 -->
  <Style x:Key="Tabla.Encabezado.Izquierda" TargetType="DataGridColumnHeader"
         BasedOn="{StaticResource Tabla.Encabezado}">
    <Setter Property="HorizontalContentAlignment" Value="Left" />
  </Style>

  <Style x:Key="Tabla.Celda" TargetType="DataGridCell">
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextoPrincipal}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="DataGridCell">
          <Border Background="{TemplateBinding Background}" Padding="12,0">
            <ContentPresenter VerticalAlignment="Center" />
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextoPrincipal}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="Tabla.Fila" TargetType="DataGridRow">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.BordeSutil}" />
    <Setter Property="BorderThickness" Value="0,0,0,0.5" />
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="{DynamicResource Brush.FondoApp}" />
      </Trigger>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="{DynamicResource Brush.PrimarioSutil}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="Tabla" TargetType="DataGrid">
    <Setter Property="AutoGenerateColumns" Value="False" />
    <Setter Property="IsReadOnly" Value="True" />
    <Setter Property="CanUserAddRows" Value="False" />
    <Setter Property="CanUserDeleteRows" Value="False" />
    <Setter Property="CanUserResizeRows" Value="False" />
    <Setter Property="CanUserReorderColumns" Value="False" />
    <Setter Property="HeadersVisibility" Value="Column" />
    <Setter Property="GridLinesVisibility" Value="None" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="RowHeight" Value="44" />
    <Setter Property="SelectionMode" Value="Single" />
    <Setter Property="SelectionUnit" Value="FullRow" />
    <Setter Property="FontFamily" Value="{StaticResource Fuente.Interfaz}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="ColumnHeaderStyle" Value="{StaticResource Tabla.Encabezado}" />
    <Setter Property="CellStyle" Value="{StaticResource Tabla.Celda}" />
    <Setter Property="RowStyle" Value="{StaticResource Tabla.Fila}" />
    <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
    <!-- Scroll horizontal: si las columnas no caben, se desplaza en vez de recortar -->
    <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
    <Setter Property="CanUserResizeColumns" Value="True" />
  </Style>

  <!-- ============================================================
       Pills de estado — DESIGN.md §8: padding 3/10, radius 6, 11px semibold
       ============================================================ -->
  <Style x:Key="Pill" TargetType="Border">
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="10,3" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style x:Key="Pill.Texto" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource Fuente.Interfaz}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <!-- Pill del semáforo de cobros: colorea según la propiedad Semaforo de la fila -->
  <Style x:Key="Pill.Semaforo" TargetType="Border" BasedOn="{StaticResource Pill}">
    <Style.Triggers>
      <DataTrigger Binding="{Binding Semaforo}" Value="{x:Static m:SemaforoCuota.AlDia}">
        <Setter Property="Background" Value="{DynamicResource Brush.AlDia.Fondo}" />
      </DataTrigger>
      <DataTrigger Binding="{Binding Semaforo}" Value="{x:Static m:SemaforoCuota.PorVencer}">
        <Setter Property="Background" Value="{DynamicResource Brush.PorVencer.Fondo}" />
      </DataTrigger>
      <DataTrigger Binding="{Binding Semaforo}" Value="{x:Static m:SemaforoCuota.Vencida}">
        <Setter Property="Background" Value="{DynamicResource Brush.Vencido.Fondo}" />
      </DataTrigger>
      <DataTrigger Binding="{Binding Semaforo}" Value="{x:Static m:SemaforoCuota.EnMora}">
        <Setter Property="Background" Value="{DynamicResource Brush.EnMora.Fondo}" />
      </DataTrigger>
      <DataTrigger Binding="{Binding Semaforo}" Value="{x:Static m:SemaforoCuota.Pagada}">
        <Setter Property="Background" Value="{DynamicResource Brush.Pagado.Fondo}" />
      </DataTrigger>
      <DataTrigger Binding="{Binding Semaforo}" Value="{x:Static m:SemaforoCuota.Cancelada}">
        <Setter Property="Background" Value="{DynamicResource Brush.Cancelado.Fondo}" />
      </DataTrigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="Pill.Semaforo.Texto" TargetType="TextBlock" BasedOn="{StaticResource Pill.Texto}">
    <Style.Triggers>
      <DataTrigger Binding="{Binding Semaforo}" Value="{x:Static m:SemaforoCuota.AlDia}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.AlDia.Texto}" />
      </DataTrigger>
      <DataTrigger Binding="{Binding Semaforo}" Value="{x:Static m:SemaforoCuota.PorVencer}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.PorVencer.Texto}" />
      </DataTrigger>
      <DataTrigger Binding="{Binding Semaforo}" Value="{x:Static m:SemaforoCuota.Vencida}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Vencido.Texto}" />
      </DataTrigger>
      <DataTrigger Binding="{Binding Semaforo}" Value="{x:Static m:SemaforoCuota.EnMora}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.EnMora.Texto}" />
      </DataTrigger>
      <DataTrigger Binding="{Binding Semaforo}" Value="{x:Static m:SemaforoCuota.Pagada}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Pagado.Texto}" />
      </DataTrigger>
      <DataTrigger Binding="{Binding Semaforo}" Value="{x:Static m:SemaforoCuota.Cancelada}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Cancelado.Texto}" />
      </DataTrigger>
    </Style.Triggers>
  </Style>

  <!-- Pill del estado de préstamo: Activo verde, Pagado azul, Cancelado gris -->
  <Style x:Key="Pill.EstadoPrestamo" TargetType="Border" BasedOn="{StaticResource Pill}">
    <Style.Triggers>
      <DataTrigger Binding="{Binding Estado}" Value="{x:Static m:EstadoPrestamo.Activo}">
        <Setter Property="Background" Value="{DynamicResource Brush.AlDia.Fondo}" />
      </DataTrigger>
      <DataTrigger Binding="{Binding Estado}" Value="{x:Static m:EstadoPrestamo.Pagado}">
        <Setter Property="Background" Value="{DynamicResource Brush.Pagado.Fondo}" />
      </DataTrigger>
      <DataTrigger Binding="{Binding Estado}" Value="{x:Static m:EstadoPrestamo.Cancelado}">
        <Setter Property="Background" Value="{DynamicResource Brush.Cancelado.Fondo}" />
      </DataTrigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="Pill.EstadoPrestamo.Texto" TargetType="TextBlock" BasedOn="{StaticResource Pill.Texto}">
    <Style.Triggers>
      <DataTrigger Binding="{Binding Estado}" Value="{x:Static m:EstadoPrestamo.Activo}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.AlDia.Texto}" />
      </DataTrigger>
      <DataTrigger Binding="{Binding Estado}" Value="{x:Static m:EstadoPrestamo.Pagado}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Pagado.Texto}" />
      </DataTrigger>
      <DataTrigger Binding="{Binding Estado}" Value="{x:Static m:EstadoPrestamo.Cancelado}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Cancelado.Texto}" />
      </DataTrigger>
    </Style.Triggers>
  </Style>

  <!-- Mini-card de métrica (resumen en detalle / preview de amortización) -->
  <Style x:Key="Card.Metrica" TargetType="Border" BasedOn="{StaticResource Card}">
    <Setter Property="Padding" Value="16,12" />
  </Style>

</ResourceDictionary>
