<UserControl x:Class="PrestControl.Views.PanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- ============ FILA 1: 4 KPIs ============ -->
    <UniformGrid Grid.Row="0" Rows="1" Columns="4" Margin="0,0,0,12">
      <Border Style="{DynamicResource Card.Metrica}" Margin="0,0,12,0">
        <StackPanel>
          <TextBlock Text="CAPITAL COLOCADO" Style="{DynamicResource Texto.MicroLabel}" />
          <TextBlock Text="{Binding CapitalColocado, Converter={StaticResource Money}}"
                     Style="{DynamicResource Texto.Display}" Margin="0,4,0,2" />
          <TextBlock Text="Saldo por cobrar de préstamos activos"
                     Style="{DynamicResource Texto.Caption}" />
        </StackPanel>
      </Border>
      <Border Style="{DynamicResource Card.Metrica}" Margin="0,0,12,0">
        <StackPanel>
          <TextBlock Text="COBROS DEL MES" Style="{DynamicResource Texto.MicroLabel}" />
          <TextBlock Text="{Binding CobrosDelMes, Converter={StaticResource Money}}"
                     Style="{DynamicResource Texto.Display}" Margin="0,4,0,2" />
          <TextBlock Text="{Binding DeltaCobrosTexto}">
            <TextBlock.Style>
              <Style TargetType="TextBlock" BasedOn="{StaticResource Texto.Caption}">
                <Setter Property="Foreground" Value="{DynamicResource Brush.DeltaNegativo}" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding DeltaCobrosPositivo}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Brush.DeltaPositivo}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </StackPanel>
      </Border>
      <Border Style="{DynamicResource Card.Metrica}" Margin="0,0,12,0">
        <StackPanel>
          <TextBlock Text="CLIENTES ACTIVOS" Style="{DynamicResource Texto.MicroLabel}" />
          <TextBlock Text="{Binding ClientesActivos}"
                     Style="{DynamicResource Texto.Display}" Margin="0,4,0,2" />
          <TextBlock Text="{Binding PrestamosActivosTexto}"
                     Style="{DynamicResource Texto.Caption}" />
        </StackPanel>
      </Border>
      <Border Style="{DynamicResource Card.Metrica}">
        <StackPanel>
          <TextBlock Text="MOROSIDAD" Style="{DynamicResource Texto.MicroLabel}" />
          <TextBlock Text="{Binding Morosidad, Converter={StaticResource Money}}"
                     Foreground="{DynamicResource Brush.Destructivo}"
                     Style="{DynamicResource Texto.Display}" Margin="0,4,0,2" />
          <TextBlock Text="{Binding MorosidadPorcentajeTexto}"
                     Style="{DynamicResource Texto.Caption}" />
        </StackPanel>
      </Border>
    </UniformGrid>

    <!-- ============ FILA 2: alertas (60%) + gráfico (40%) ============ -->
    <Grid Grid.Row="1" Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="6*" />
        <ColumnDefinition Width="4*" />
      </Grid.ColumnDefinitions>

      <!-- Alertas de cobro -->
      <Border Grid.Column="0" Style="{DynamicResource Card}" Margin="0,0,12,0" Padding="20,14">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Text="Alertas de cobro" Style="{DynamicResource Texto.Titulo3}"
                     Margin="0,0,0,8" />
          <TextBlock Grid.Row="1" Text="Sin cuotas vencidas ni por vencer. ¡Todo al día!"
                     HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock.Style>
              <Style TargetType="TextBlock" BasedOn="{StaticResource Texto.Caption}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding TieneAlertas}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0"
                        Visibility="{Binding TieneAlertas, Converter={StaticResource BoolAVisibilidad}}">
            <ItemsControl ItemsSource="{Binding Alertas}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border BorderBrush="{DynamicResource Brush.BordeSutil}"
                          BorderThickness="0,0,0,0.5" Padding="0,8">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <Border Grid.Column="0" Style="{DynamicResource Pill.Semaforo}">
                        <TextBlock Text="{Binding SemaforoTexto}"
                                   Style="{DynamicResource Pill.Semaforo.Texto}" />
                      </Border>
                      <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Style="{DynamicResource Texto.CuerpoEnfatizado}">
                          <Run Text="{Binding ClienteNombre, Mode=OneWay}" />
                          <Run Text="{Binding Codigo, Mode=OneWay}"
                               Foreground="{DynamicResource Brush.TextoTerciario}" />
                        </TextBlock>
                        <TextBlock Text="{Binding CuotaTexto}" Style="{DynamicResource Texto.Caption}" />
                      </StackPanel>
                      <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="0,0,12,0"
                                 Text="{Binding SaldoPendiente, Converter={StaticResource Money}}"
                                 Style="{DynamicResource Texto.MontoTotal}" />
                      <Button Grid.Column="3" Content="Cobrar" Style="{DynamicResource Boton.Terciario}"
                              Command="{Binding DataContext.CobrarCommand,
                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                              CommandParameter="{Binding}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>

      <!-- Gráfico de tendencia -->
      <Border Grid.Column="1" Style="{DynamicResource Card}" Padding="20,14">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Text="{Binding MesTexto}" Style="{DynamicResource Texto.Titulo3}"
                     Margin="0,0,0,8" />
          <lvc:CartesianChart Grid.Row="1"
                              Series="{Binding Series}"
                              XAxes="{Binding XAxes}"
                              YAxes="{Binding YAxes}" />
        </Grid>
      </Border>
    </Grid>

    <!-- ============ FILA 3: últimos movimientos ============ -->
    <Border Grid.Row="2" Style="{DynamicResource Card}" Padding="20,14" MaxHeight="240">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Últimos movimientos" Style="{DynamicResource Texto.Titulo3}"
                   Margin="0,0,0,8" />
        <TextBlock Grid.Row="1" Text="Aún no hay pagos registrados."
                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,12">
          <TextBlock.Style>
            <Style TargetType="TextBlock" BasedOn="{StaticResource Texto.Caption}">
              <Style.Triggers>
                <DataTrigger Binding="{Binding TieneMovimientos}" Value="True">
                  <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
        <DataGrid Grid.Row="1" Style="{DynamicResource Tabla}" RowHeight="36"
                  ItemsSource="{Binding Movimientos}"
                  Visibility="{Binding TieneMovimientos, Converter={StaticResource BoolAVisibilidad}}">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Recibo" Binding="{Binding NumeroRecibo}" Width="100">
              <DataGridTextColumn.ElementStyle>
                <Style TargetType="TextBlock">
                  <Setter Property="FontFamily" Value="{DynamicResource Fuente.Mono}" />
                </Style>
              </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>
            <DataGridTextColumn Header="Fecha" Binding="{Binding FechaTexto}" Width="150" />
            <DataGridTextColumn Header="Cliente" Binding="{Binding ClienteNombre}" Width="*"
                                HeaderStyle="{StaticResource Tabla.Encabezado.Izquierda}" />
            <DataGridTextColumn Header="Préstamo" Binding="{Binding PrestamoCodigo}" Width="90" />
            <DataGridTextColumn Header="Cuota" Binding="{Binding CuotaTexto}" Width="80" />
            <DataGridTextColumn Header="Monto"
                                Binding="{Binding MontoPagado, Converter={StaticResource Money}}" Width="120">
              <DataGridTextColumn.ElementStyle>
                <Style TargetType="TextBlock" BasedOn="{StaticResource Texto.Monto}" />
              </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>
            <DataGridTextColumn Header="Método" Binding="{Binding MetodoTexto}" Width="110" />
          </DataGrid.Columns>
        </DataGrid>
      </Grid>
    </Border>
  </Grid>
</UserControl>
