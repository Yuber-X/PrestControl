<UserControl x:Class="PrestControl.Views.ReportesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Barra de rango: fechas + atajos + generar/exportar -->
    <Border Grid.Row="0" Style="{DynamicResource Card}" Padding="20,14" Margin="0,0,0,12">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <Button Content="Generar reporte" Style="{DynamicResource Boton.Primario}"
                  Command="{Binding GenerarCommand}" Margin="0,0,8,0" />
          <Button Content="Exportar Excel" Style="{DynamicResource Boton.Secundario}"
                  Click="BotonExportar_Click" />
        </StackPanel>
        <StackPanel Orientation="Horizontal">
          <StackPanel Margin="0,0,12,0">
            <TextBlock Text="Desde" Style="{DynamicResource Input.Label}" />
            <DatePicker Width="140" Height="40" FontSize="13"
                        SelectedDate="{Binding Desde}" />
          </StackPanel>
          <StackPanel Margin="0,0,16,0">
            <TextBlock Text="Hasta" Style="{DynamicResource Input.Label}" />
            <DatePicker Width="140" Height="40" FontSize="13"
                        SelectedDate="{Binding Hasta}" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
            <Button Content="Este mes" Style="{DynamicResource Boton.Terciario}"
                    Command="{Binding EsteMesCommand}" Margin="0,0,4,4" />
            <Button Content="Mes pasado" Style="{DynamicResource Boton.Terciario}"
                    Command="{Binding MesPasadoCommand}" Margin="0,0,4,4" />
            <Button Content="Trimestre" Style="{DynamicResource Boton.Terciario}"
                    Command="{Binding TrimestreCommand}" Margin="0,0,4,4" />
            <Button Content="Año" Style="{DynamicResource Boton.Terciario}"
                    Command="{Binding AnioCommand}" Margin="0,0,0,4" />
          </StackPanel>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- KPIs del período -->
    <UniformGrid Grid.Row="1" Rows="1" Columns="4" Margin="0,0,0,12"
                 Visibility="{Binding TieneReporte, Converter={StaticResource BoolAVisibilidad}}">
      <!-- Ganancia: card destacada indigo (mockup) -->
      <Border Style="{DynamicResource Card.Metrica}" Margin="0,0,12,0"
              Background="{DynamicResource Brush.Primario}">
        <StackPanel>
          <TextBlock Text="GANANCIA (INTERÉS COBRADO)" Style="{DynamicResource Texto.MicroLabel}"
                     Foreground="#C7CBFB" />
          <TextBlock Text="{Binding InteresCobrado, Converter={StaticResource Money}}"
                     Style="{DynamicResource Texto.Display}" Foreground="White" Margin="0,4,0,2" />
          <TextBlock Text="{Binding RangoTexto}" Style="{DynamicResource Texto.Caption}"
                     Foreground="#C7CBFB" />
        </StackPanel>
      </Border>
      <Border Style="{DynamicResource Card.Metrica}" Margin="0,0,12,0">
        <StackPanel>
          <TextBlock Text="CAPITAL RECUPERADO" Style="{DynamicResource Texto.MicroLabel}" />
          <TextBlock Text="{Binding CapitalRecuperado, Converter={StaticResource Money}}"
                     Style="{DynamicResource Texto.Display}" Margin="0,4,0,2" />
          <TextBlock Text="Abonado al principal" Style="{DynamicResource Texto.Caption}" />
        </StackPanel>
      </Border>
      <Border Style="{DynamicResource Card.Metrica}" Margin="0,0,12,0">
        <StackPanel>
          <TextBlock Text="TOTAL COBRADO" Style="{DynamicResource Texto.MicroLabel}" />
          <TextBlock Text="{Binding TotalCobrado, Converter={StaticResource Money}}"
                     Style="{DynamicResource Texto.Display}" Margin="0,4,0,2" />
          <TextBlock Text="Capital + interés" Style="{DynamicResource Texto.Caption}" />
        </StackPanel>
      </Border>
      <Border Style="{DynamicResource Card.Metrica}">
        <StackPanel>
          <TextBlock Text="CUOTAS COBRADAS" Style="{DynamicResource Texto.MicroLabel}" />
          <TextBlock Text="{Binding CuotasCobradas}"
                     Style="{DynamicResource Texto.Display}" Margin="0,4,0,2" />
          <TextBlock Text="{Binding CuotasProgramadasTexto}" Style="{DynamicResource Texto.Caption}" />
        </StackPanel>
      </Border>
    </UniformGrid>

    <!-- Gráfico semanal + desglose -->
    <Grid Grid.Row="2"
          Visibility="{Binding TieneReporte, Converter={StaticResource BoolAVisibilidad}}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="55*" />
        <ColumnDefinition Width="45*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Style="{DynamicResource Card}" Margin="0,0,12,0" Padding="20,14">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
              <Rectangle Width="10" Height="10" RadiusX="2" RadiusY="2"
                         Fill="{DynamicResource Brush.Primario}" />
              <TextBlock Text="Interés" Style="{DynamicResource Texto.Caption}" Margin="4,0,12,0" />
              <Rectangle Width="10" Height="10" RadiusX="2" RadiusY="2"
                         Fill="{DynamicResource Brush.BordeEstandar}" />
              <TextBlock Text="Capital" Style="{DynamicResource Texto.Caption}" Margin="4,0,0,0" />
            </StackPanel>
            <TextBlock Text="Ganancia por semana" Style="{DynamicResource Texto.Titulo3}" />
          </DockPanel>
          <lvc:CartesianChart Grid.Row="1"
                              Series="{Binding Series}"
                              XAxes="{Binding XAxes}"
                              YAxes="{Binding YAxes}" />
        </Grid>
      </Border>

      <Border Grid.Column="1" Style="{DynamicResource Card}" Padding="20,14">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Text="Desglose por semana" Style="{DynamicResource Texto.Titulo3}"
                     Margin="0,0,0,8" />
          <DataGrid Grid.Row="1" Style="{DynamicResource Tabla}" RowHeight="38"
                    ItemsSource="{Binding Semanas}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Semana" Binding="{Binding Etiqueta}" Width="*"
                                  HeaderStyle="{StaticResource Tabla.Encabezado.Izquierda}" />
              <DataGridTextColumn Header="Capital"
                                  Binding="{Binding Capital, Converter={StaticResource Money}}" Width="130">
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock" BasedOn="{StaticResource Texto.Monto}" />
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>
              <DataGridTextColumn Header="Interés"
                                  Binding="{Binding Interes, Converter={StaticResource Money}}" Width="130">
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock" BasedOn="{StaticResource Texto.MontoTotal}">
                    <Setter Property="Foreground" Value="{DynamicResource Brush.DeltaPositivo}" />
                  </Style>
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>
            </DataGrid.Columns>
          </DataGrid>
          <!-- Fila de totales (fondo gris, semibold — DESIGN.md) -->
          <Border Grid.Row="2" Background="{DynamicResource Brush.FondoEncabezadoTabla}"
                  CornerRadius="6" Padding="12,8" Margin="0,4,0,0">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="130" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="Total" Style="{DynamicResource Texto.CuerpoEnfatizado}" />
              <TextBlock Grid.Column="1" Style="{DynamicResource Texto.MontoTotal}" Margin="0,0,12,0"
                         Text="{Binding TotalCapitalSemanas, Converter={StaticResource Money}}" />
              <TextBlock Grid.Column="2" Style="{DynamicResource Texto.MontoTotal}"
                         Foreground="{DynamicResource Brush.DeltaPositivo}"
                         Text="{Binding TotalInteresSemanas, Converter={StaticResource Money}}" />
            </Grid>
          </Border>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>
