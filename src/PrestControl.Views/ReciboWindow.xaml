<Window x:Class="PrestControl.Views.ReciboWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recibo de pago"
        Width="420" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.FondoApp}"
        ResizeMode="NoResize">

  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Vista previa del recibo (mismo visual que se imprime) -->
    <Border Grid.Row="0" Background="White" CornerRadius="8"
            BorderBrush="{DynamicResource Brush.BordeEstandar}" BorderThickness="1">
      <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalAlignment="Center">
        <ContentControl x:Name="ContenedorRecibo" Margin="12" />
      </ScrollViewer>
    </Border>

    <!-- Acciones -->
    <Grid Grid.Row="1" Margin="0,16,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="8" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="8" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Button Grid.Column="0" Content="Imprimir" Style="{DynamicResource Boton.Primario}"
              Click="BotonImprimir_Click" />
      <Button Grid.Column="2" Content="Guardar PDF" Style="{DynamicResource Boton.Secundario}"
              Click="BotonPdf_Click" />
      <Button Grid.Column="4" Content="Cerrar" Style="{DynamicResource Boton.Secundario}"
              Click="BotonCerrar_Click" />
    </Grid>
  </Grid>
</Window>
