<UserControl x:Class="PrestControl.Views.ClientesListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Toolbar -->
    <DockPanel Grid.Row="0" Margin="0,0,0,16">
      <Button DockPanel.Dock="Right" Content="+ Nuevo cliente"
              Style="{DynamicResource Boton.Primario}"
              Command="{Binding NuevoCommand}" />
      <StackPanel Orientation="Horizontal">
        <TextBox Width="320"
                 Style="{DynamicResource Input.Texto}"
                 Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}"
                 ToolTip="Buscar por nombre, cédula o teléfono" />
        <ComboBox Width="190" Height="40" FontSize="13" Margin="12,0,0,0"
                  ItemsSource="{Binding Filtros}"
                  SelectedItem="{Binding FiltroSeleccionado}" />
      </StackPanel>
    </DockPanel>

    <!-- Tabla -->
    <Border Grid.Row="1" Style="{DynamicResource Card}" Padding="0">
      <DataGrid Style="{DynamicResource Tabla}"
                ItemsSource="{Binding Filas}"
                MouseDoubleClick="Tabla_MouseDoubleClick">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Cédula" Binding="{Binding Cedula}" Width="130">
            <DataGridTextColumn.ElementStyle>
              <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{DynamicResource Fuente.Mono}" />
              </Style>
            </DataGridTextColumn.ElementStyle>
          </DataGridTextColumn>
          <DataGridTextColumn Header="Nombre" Binding="{Binding NombreCompleto}" Width="*" />
          <DataGridTextColumn Header="Teléfono" Binding="{Binding TelefonoTexto}" Width="130" />
          <DataGridTextColumn Header="Préstamos activos" Binding="{Binding PrestamosActivos}" Width="130">
            <DataGridTextColumn.ElementStyle>
              <Style TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Center" />
              </Style>
            </DataGridTextColumn.ElementStyle>
          </DataGridTextColumn>
          <DataGridTextColumn Header="Saldo pendiente"
                              Binding="{Binding SaldoPendiente, Converter={StaticResource Money}}"
                              Width="150">
            <DataGridTextColumn.ElementStyle>
              <Style TargetType="TextBlock" BasedOn="{StaticResource Texto.Monto}" />
            </DataGridTextColumn.ElementStyle>
          </DataGridTextColumn>
          <DataGridTemplateColumn Width="90">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Button Content="Ver ficha" Style="{DynamicResource Boton.Terciario}"
                        Command="{Binding DataContext.VerFichaCommand,
                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                        CommandParameter="{Binding}" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <TextBlock Grid.Row="2" Text="{Binding ContadorTexto}"
               Style="{DynamicResource Texto.Caption}" Margin="4,10,0,0" />
  </Grid>
</UserControl>
