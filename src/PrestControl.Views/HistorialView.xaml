<UserControl x:Class="PrestControl.Views.HistorialView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Filtros -->
    <Border Grid.Row="0" Style="{DynamicResource Card}" Padding="20,14" Margin="0,0,0,12">
      <StackPanel Orientation="Horizontal">
        <StackPanel Margin="0,0,12,0">
          <TextBlock Text="Desde" Style="{DynamicResource Input.Label}" />
          <DatePicker Width="140" Height="40" FontSize="13" SelectedDate="{Binding Desde}" />
        </StackPanel>
        <StackPanel Margin="0,0,12,0">
          <TextBlock Text="Hasta" Style="{DynamicResource Input.Label}" />
          <DatePicker Width="140" Height="40" FontSize="13" SelectedDate="{Binding Hasta}" />
        </StackPanel>
        <StackPanel Margin="0,0,12,0">
          <TextBlock Text="Entidad" Style="{DynamicResource Input.Label}" />
          <ComboBox Width="170" Height="40" FontSize="13"
                    ItemsSource="{Binding Entidades}"
                    SelectedItem="{Binding EntidadSeleccionada}" />
        </StackPanel>
        <StackPanel Margin="0,0,16,0">
          <TextBlock Text="Acción" Style="{DynamicResource Input.Label}" />
          <ComboBox Width="170" Height="40" FontSize="13"
                    ItemsSource="{Binding Acciones}"
                    SelectedItem="{Binding AccionSeleccionada}" />
        </StackPanel>
        <Button Content="Limpiar filtros" Style="{DynamicResource Boton.Terciario}"
                VerticalAlignment="Bottom" Margin="0,0,0,6"
                Command="{Binding LimpiarFiltrosCommand}" />
      </StackPanel>
    </Border>

    <!-- Tabla de auditoría (solo lectura) -->
    <Border Grid.Row="1" Style="{DynamicResource Card}" Padding="0">
      <DataGrid Style="{DynamicResource Tabla}" RowHeight="38" ItemsSource="{Binding Filas}">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Fecha y hora" Binding="{Binding FechaTexto}" Width="170" />
          <DataGridTextColumn Header="Acción" Binding="{Binding AccionTexto}" Width="130"
                              HeaderStyle="{StaticResource Tabla.Encabezado.Izquierda}" />
          <DataGridTextColumn Header="Entidad" Binding="{Binding EntidadTexto}" Width="100"
                              HeaderStyle="{StaticResource Tabla.Encabezado.Izquierda}" />
          <DataGridTextColumn Header="Id" Binding="{Binding EntidadIdTexto}" Width="60" />
          <DataGridTextColumn Header="Descripción" Binding="{Binding DescripcionTexto}" Width="*"
                              HeaderStyle="{StaticResource Tabla.Encabezado.Izquierda}">
            <DataGridTextColumn.ElementStyle>
              <Style TargetType="TextBlock">
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="ToolTip" Value="{Binding DescripcionTexto}" />
              </Style>
            </DataGridTextColumn.ElementStyle>
          </DataGridTextColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <TextBlock Grid.Row="2" Text="{Binding ContadorTexto}"
               Style="{DynamicResource Texto.Caption}" Margin="4,10,0,0" />
  </Grid>
</UserControl>
