<Window x:Class="PrestControl.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PrestControl — Iniciar sesión"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.FondoApp}">

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolAVisibilidad" />
  </Window.Resources>

  <Grid>
    <!-- SizeToContent: la ventana crece sola cuando el wizard muestra los campos extra -->
    <Border Style="{DynamicResource Card}" Width="360" VerticalAlignment="Center"
            Padding="32" Margin="0,40">
      <StackPanel>

        <!-- Encabezado -->
        <TextBlock Text="PrestControl" Style="{DynamicResource Texto.Titulo1}"
                   HorizontalAlignment="Center" />
        <TextBlock Text="Gestión de préstamos" Style="{DynamicResource Texto.Caption}"
                   HorizontalAlignment="Center" Margin="0,4,0,24" />

        <!-- Título contextual (login vs primer arranque) -->
        <TextBlock x:Name="TituloContexto" Text="Inicia sesión para continuar"
                   Style="{DynamicResource Texto.Titulo3}" Margin="0,0,0,16" />

        <!-- Usuario -->
        <TextBlock Text="Usuario" Style="{DynamicResource Input.Label}" />
        <TextBox x:Name="CajaUsuario" Style="{DynamicResource Input.Texto}"
                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,12" />

        <!-- Nombre (solo wizard) -->
        <StackPanel Visibility="{Binding EsWizardInicial, Converter={StaticResource BoolAVisibilidad}}">
          <TextBlock Text="Tu nombre" Style="{DynamicResource Input.Label}" />
          <TextBox Style="{DynamicResource Input.Texto}"
                   Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"
                   Margin="0,0,0,12" />
        </StackPanel>

        <!-- Contraseña -->
        <TextBlock Text="Contraseña" Style="{DynamicResource Input.Label}" />
        <PasswordBox x:Name="CajaPassword" Style="{DynamicResource Input.Password}"
                     Margin="0,0,0,12" KeyDown="CajaPassword_KeyDown" />

        <!-- Confirmación (solo wizard) -->
        <StackPanel Visibility="{Binding EsWizardInicial, Converter={StaticResource BoolAVisibilidad}}">
          <TextBlock Text="Confirmar contraseña" Style="{DynamicResource Input.Label}" />
          <PasswordBox x:Name="CajaConfirmacion" Style="{DynamicResource Input.Password}"
                       Margin="0,0,0,12" />
        </StackPanel>

        <!-- Error -->
        <TextBlock Text="{Binding MensajeError}"
                   Style="{DynamicResource Texto.Caption}"
                   Foreground="{DynamicResource Brush.Destructivo}"
                   TextWrapping="Wrap" Margin="0,0,0,12" />

        <!-- Acción -->
        <Button x:Name="BotonAccion" Content="Iniciar sesión"
                Style="{DynamicResource Boton.Primario}"
                IsEnabled="{Binding Ocupado, Converter={StaticResource InversorBool}}"
                Click="BotonAccion_Click" />

      </StackPanel>
    </Border>
  </Grid>
</Window>
