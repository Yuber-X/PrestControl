<UserControl x:Class="PrestControl.Views.ClienteFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Formulario centrado, ancho máximo 640 (DESIGN.md §9) -->
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Border Style="{DynamicResource Card}" MaxWidth="640" VerticalAlignment="Top"
            HorizontalAlignment="Center" Padding="32" Margin="0,8">
      <StackPanel>
        <TextBlock Text="{Binding Titulo}" Style="{DynamicResource Texto.Titulo2}"
                   Margin="0,0,0,20" />

        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0">
            <TextBlock Text="Nombre" Style="{DynamicResource Input.Label}" />
            <TextBox Style="{DynamicResource Input.Texto}"
                     Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}" />
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Text="Apellido" Style="{DynamicResource Input.Label}" />
            <TextBox Style="{DynamicResource Input.Texto}"
                     Text="{Binding Apellido, UpdateSourceTrigger=PropertyChanged}" />
          </StackPanel>
        </Grid>

        <Grid Margin="0,14,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0">
            <TextBlock Text="Cédula" Style="{DynamicResource Input.Label}" />
            <TextBox Style="{DynamicResource Input.Texto}"
                     Text="{Binding Cedula, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="001-1234567-8 (o pasaporte para extranjeros)" />
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Text="Teléfono" Style="{DynamicResource Input.Label}" />
            <TextBox Style="{DynamicResource Input.Texto}"
                     Text="{Binding Telefono, UpdateSourceTrigger=PropertyChanged}" />
          </StackPanel>
        </Grid>

        <TextBlock Text="Dirección" Style="{DynamicResource Input.Label}" Margin="0,14,0,6" />
        <TextBox Style="{DynamicResource Input.Texto}"
                 Text="{Binding Direccion, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Text="Correo electrónico" Style="{DynamicResource Input.Label}" Margin="0,14,0,6" />
        <TextBox Style="{DynamicResource Input.Texto}"
                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Text="Notas" Style="{DynamicResource Input.Label}" Margin="0,14,0,6" />
        <TextBox Style="{DynamicResource Input.Texto}" Height="72"
                 TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalContentAlignment="Top" Padding="10,8"
                 Text="{Binding Notas, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Text="{Binding MensajeError}"
                   Foreground="{DynamicResource Brush.Destructivo}"
                   Style="{DynamicResource Texto.Caption}"
                   TextWrapping="Wrap" Margin="0,12,0,0" />

        <!-- Botones fijos abajo: Cancelar / Guardar -->
        <Grid Margin="0,20,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Button Grid.Column="0" Content="Cancelar" Style="{DynamicResource Boton.Secundario}"
                  Command="{Binding CancelarCommand}" />
          <Button Grid.Column="2" Content="Guardar cliente" Style="{DynamicResource Boton.Primario}"
                  Command="{Binding GuardarCommand}"
                  IsEnabled="{Binding Ocupado, Converter={StaticResource InversorBool}}" />
        </Grid>
      </StackPanel>
    </Border>
  </ScrollViewer>
</UserControl>
