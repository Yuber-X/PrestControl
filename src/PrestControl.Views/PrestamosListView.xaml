<UserControl x:Class="PrestControl.Views.PrestamosListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Totales del grid: sin calculadora (pedido de Yuber, punto 5) -->
    <UniformGrid Grid.Row="0" Rows="1" Columns="4" Margin="0,0,0,12">
      <Border Style="{DynamicResource Card.Metrica}" Margin="0,0,12,0">
        <StackPanel>
          <TextBlock Text="CAPITAL PRESTADO" Style="{DynamicResource Texto.MicroLabel}" />
          <TextBlock Text="{Binding TotalCapital, Converter={StaticResource Money}}"
                     Style="{DynamicResource Texto.Titulo2}" Margin="0,4,0,0" />
        </StackPanel>
      </Border>
      <Border Style="{DynamicResource Card.Metrica}" Margin="0,0,12,0">
        <StackPanel>
          <TextBlock Text="POR COBRAR (ACTIVOS)" Style="{DynamicResource Texto.MicroLabel}" />
          <TextBlock Text="{Binding TotalPorCobrar, Converter={StaticResource Money}}"
                     Style="{DynamicResource Texto.Titulo2}" Margin="0,4,0,0" />
        </StackPanel>
      </Border>
      <Border Style="{DynamicResource Card.Metrica}" Margin="0,0,12,0">
        <StackPanel>
          <TextBlock Text="TOTAL COBRADO" Style="{DynamicResource Texto.MicroLabel}" />
          <TextBlock Text="{Binding TotalCobrado, Converter={StaticResource Money}}"
                     Style="{DynamicResource Texto.Titulo2}" Margin="0,4,0,0" />
        </StackPanel>
      </Border>
      <Border Style="{DynamicResource Card.Metrica}">
        <StackPanel>
          <TextBlock Text="PRÉSTAMOS ACTIVOS" Style="{DynamicResource Texto.MicroLabel}" />
          <TextBlock Text="{Binding TotalActivos}"
                     Style="{DynamicResource Texto.Titulo2}" Margin="0,4,0,0" />
        </StackPanel>
      </Border>
    </UniformGrid>

    <!-- Toolbar: búsqueda + filtro de estado + Nuevo préstamo -->
    <DockPanel Grid.Row="1" Margin="0,0,0,16">
      <Button DockPanel.Dock="Right" Content="+ Nuevo préstamo"
              Style="{DynamicResource Boton.Primario}"
              Command="{Binding NuevoCommand}" />
      <StackPanel Orientation="Horizontal">
        <TextBox Width="320"
                 Style="{DynamicResource Input.Texto}"
                 Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}"
                 ToolTip="Buscar por código o cliente" />
        <ComboBox Width="170" Height="40" FontSize="13" Margin="12,0,0,0"
                  ItemsSource="{Binding FiltrosEstado}"
                  SelectedItem="{Binding FiltroEstado}" />
      </StackPanel>
    </DockPanel>

    <!-- Tabla -->
    <Border Grid.Row="2" Style="{DynamicResource Card}" Padding="0">
      <DataGrid Style="{DynamicResource Tabla}"
                ItemsSource="{Binding Filas}"
                MouseDoubleClick="Tabla_MouseDoubleClick">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="90">
            <DataGridTextColumn.ElementStyle>
              <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{DynamicResource Fuente.Mono}" />
              </Style>
            </DataGridTextColumn.ElementStyle>
          </DataGridTextColumn>
          <DataGridTextColumn Header="Cliente" Binding="{Binding ClienteNombre}" Width="*" />
          <DataGridTextColumn Header="Capital"
                              Binding="{Binding MontoCapital, Converter={StaticResource Money}}"
                              Width="130">
            <DataGridTextColumn.ElementStyle>
              <Style TargetType="TextBlock" BasedOn="{StaticResource Texto.Monto}" />
            </DataGridTextColumn.ElementStyle>
          </DataGridTextColumn>
          <DataGridTextColumn Header="Tasa" Binding="{Binding TasaTexto}" Width="110" />
          <DataGridTextColumn Header="Modalidad" Binding="{Binding ModalidadTexto}" Width="90" />
          <DataGridTextColumn Header="Cuotas" Binding="{Binding ProgresoTexto}" Width="70" />
          <DataGridTextColumn Header="Saldo pendiente"
                              Binding="{Binding SaldoPendiente, Converter={StaticResource Money}}"
                              Width="140">
            <DataGridTextColumn.ElementStyle>
              <Style TargetType="TextBlock" BasedOn="{StaticResource Texto.Monto}" />
            </DataGridTextColumn.ElementStyle>
          </DataGridTextColumn>
          <DataGridTextColumn Header="Próx. venc." Binding="{Binding ProximoVencimientoTexto}" Width="100" />
          <DataGridTemplateColumn Header="Estado" Width="100"
                                  HeaderStyle="{StaticResource Tabla.Encabezado.Izquierda}">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Border Style="{DynamicResource Pill.EstadoPrestamo}">
                  <TextBlock Text="{Binding EstadoTexto}"
                             Style="{DynamicResource Pill.EstadoPrestamo.Texto}" />
                </Border>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTemplateColumn Width="120">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Button Content="Ver detalle" Style="{DynamicResource Boton.Terciario}"
                        Command="{Binding DataContext.VerDetalleCommand,
                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                        CommandParameter="{Binding}" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <!-- Contador de resultados -->
    <TextBlock Grid.Row="3" Text="{Binding ContadorTexto}"
               Style="{DynamicResource Texto.Caption}" Margin="4,10,0,0" />
  </Grid>
</UserControl>
