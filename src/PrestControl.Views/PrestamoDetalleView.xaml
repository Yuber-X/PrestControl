<UserControl x:Class="PrestControl.Views.PrestamoDetalleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header: volver + código/cliente + acciones -->
    <DockPanel Grid.Row="0" Margin="0,0,0,16">
      <Button DockPanel.Dock="Left" Content="← Préstamos"
              Style="{DynamicResource Boton.Terciario}"
              VerticalAlignment="Center"
              Command="{Binding VolverCommand}" />
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
        <Button Content="Cancelar préstamo" Style="{DynamicResource Boton.Destructivo}"
                Command="{Binding CancelarPrestamoCommand}"
                Visibility="{Binding EsActivo, Converter={StaticResource BoolAVisibilidad}}"
                Margin="0,0,8,0" />
        <Button Content="Registrar pago" Style="{DynamicResource Boton.Primario}"
                Command="{Binding CobrarCommand}"
                Visibility="{Binding EsActivo, Converter={StaticResource BoolAVisibilidad}}" />
      </StackPanel>
      <StackPanel Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
        <TextBlock Text="{Binding Codigo}" Style="{DynamicResource Texto.Titulo2}"
                   FontFamily="{DynamicResource Fuente.Mono}" VerticalAlignment="Center" />
        <TextBlock Text="{Binding ClienteNombre}" Style="{DynamicResource Texto.Titulo2}"
                   Margin="12,0,12,0" VerticalAlignment="Center" />
        <Border Style="{DynamicResource Pill.EstadoPrestamo}" VerticalAlignment="Center">
          <TextBlock Text="{Binding EstadoTexto}" Style="{DynamicResource Pill.EstadoPrestamo.Texto}" />
        </Border>
      </StackPanel>
    </DockPanel>

    <!-- Métricas -->
    <UniformGrid Grid.Row="1" Rows="1" Columns="4" Margin="0,0,0,12">
      <Border Style="{DynamicResource Card.Metrica}" Margin="0,0,12,0">
        <StackPanel>
          <TextBlock Text="CAPITAL PRESTADO" Style="{DynamicResource Texto.MicroLabel}" />
          <TextBlock Text="{Binding MontoCapital, Converter={StaticResource Money}}"
                     Style="{DynamicResource Texto.Titulo2}" Margin="0,4,0,0" />
        </StackPanel>
      </Border>
      <Border Style="{DynamicResource Card.Metrica}" Margin="0,0,12,0">
        <StackPanel>
          <TextBlock Text="TOTAL A PAGAR" Style="{DynamicResource Texto.MicroLabel}" />
          <TextBlock Text="{Binding TotalAPagar, Converter={StaticResource Money}}"
                     Style="{DynamicResource Texto.Titulo2}" Margin="0,4,0,0" />
        </StackPanel>
      </Border>
      <Border Style="{DynamicResource Card.Metrica}" Margin="0,0,12,0">
        <StackPanel>
          <TextBlock Text="COBRADO" Style="{DynamicResource Texto.MicroLabel}" />
          <TextBlock Text="{Binding TotalPagado, Converter={StaticResource Money}}"
                     Style="{DynamicResource Texto.Titulo2}" Margin="0,4,0,0" />
        </StackPanel>
      </Border>
      <Border Style="{DynamicResource Card.Metrica}">
        <StackPanel>
          <TextBlock Text="SALDO PENDIENTE" Style="{DynamicResource Texto.MicroLabel}" />
          <TextBlock Text="{Binding SaldoPendiente, Converter={StaticResource Money}}"
                     Style="{DynamicResource Texto.Titulo2}" Margin="0,4,0,0" />
        </StackPanel>
      </Border>
    </UniformGrid>

    <!-- Datos del contrato -->
    <Border Grid.Row="2" Style="{DynamicResource Card}" Margin="0,0,0,12" Padding="20,14">
      <WrapPanel>
        <StackPanel Margin="0,0,32,0">
          <TextBlock Text="TASA" Style="{DynamicResource Texto.MicroLabel}" />
          <TextBlock Text="{Binding TasaTexto}" Style="{DynamicResource Texto.CuerpoEnfatizado}" />
        </StackPanel>
        <StackPanel Margin="0,0,32,0">
          <TextBlock Text="MODALIDAD" Style="{DynamicResource Texto.MicroLabel}" />
          <TextBlock Text="{Binding ModalidadTexto}" Style="{DynamicResource Texto.CuerpoEnfatizado}" />
        </StackPanel>
        <StackPanel Margin="0,0,32,0">
          <TextBlock Text="MÉTODO" Style="{DynamicResource Texto.MicroLabel}" />
          <TextBlock Text="{Binding MetodoTexto}" Style="{DynamicResource Texto.CuerpoEnfatizado}" />
        </StackPanel>
        <StackPanel Margin="0,0,32,0">
          <TextBlock Text="PRIMER PAGO" Style="{DynamicResource Texto.MicroLabel}" />
          <TextBlock Text="{Binding FechaInicioTexto}" Style="{DynamicResource Texto.CuerpoEnfatizado}" />
        </StackPanel>
        <StackPanel Margin="0,0,32,0">
          <TextBlock Text="PROGRESO" Style="{DynamicResource Texto.MicroLabel}" />
          <TextBlock Text="{Binding ProgresoTexto}" Style="{DynamicResource Texto.CuerpoEnfatizado}" />
        </StackPanel>
        <StackPanel Margin="0,0,32,0">
          <TextBlock Text="GARANTÍA" Style="{DynamicResource Texto.MicroLabel}" />
          <TextBlock Text="{Binding GarantiaTexto}" Style="{DynamicResource Texto.CuerpoEnfatizado}" />
        </StackPanel>
        <StackPanel>
          <TextBlock Text="NOTAS" Style="{DynamicResource Texto.MicroLabel}" />
          <TextBlock Text="{Binding NotasTexto}" Style="{DynamicResource Texto.CuerpoEnfatizado}"
                     TextWrapping="Wrap" MaxWidth="360" />
        </StackPanel>
      </WrapPanel>
    </Border>

    <!-- Tabla de cuotas -->
    <Border Grid.Row="3" Style="{DynamicResource Card}" Padding="0">
      <DataGrid Style="{DynamicResource Tabla}" ItemsSource="{Binding Cuotas}">
        <DataGrid.RowStyle>
          <!-- Cuotas vencidas: indicador rojo lateral izquierdo (DESIGN.md §9) -->
          <Style TargetType="DataGridRow" BasedOn="{StaticResource Tabla.Fila}">
            <Style.Triggers>
              <DataTrigger Binding="{Binding EstaVencida}" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Destructivo}" />
                <Setter Property="BorderThickness" Value="3,0,0,0.5" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </DataGrid.RowStyle>
        <DataGrid.Columns>
          <DataGridTextColumn Header="N°" Binding="{Binding Numero}" Width="50" />
          <DataGridTextColumn Header="Vencimiento" Binding="{Binding FechaTexto}" Width="110" />
          <DataGridTextColumn Header="Capital"
                              Binding="{Binding Capital, Converter={StaticResource Money}}" Width="120">
            <DataGridTextColumn.ElementStyle>
              <Style TargetType="TextBlock" BasedOn="{StaticResource Texto.Monto}" />
            </DataGridTextColumn.ElementStyle>
          </DataGridTextColumn>
          <DataGridTextColumn Header="Interés"
                              Binding="{Binding Interes, Converter={StaticResource Money}}" Width="120">
            <DataGridTextColumn.ElementStyle>
              <Style TargetType="TextBlock" BasedOn="{StaticResource Texto.Monto}" />
            </DataGridTextColumn.ElementStyle>
          </DataGridTextColumn>
          <DataGridTextColumn Header="Cuota"
                              Binding="{Binding MontoTotal, Converter={StaticResource Money}}" Width="120">
            <DataGridTextColumn.ElementStyle>
              <Style TargetType="TextBlock" BasedOn="{StaticResource Texto.MontoTotal}" />
            </DataGridTextColumn.ElementStyle>
          </DataGridTextColumn>
          <DataGridTextColumn Header="Abonado"
                              Binding="{Binding MontoPagado, Converter={StaticResource Money}}" Width="120">
            <DataGridTextColumn.ElementStyle>
              <Style TargetType="TextBlock" BasedOn="{StaticResource Texto.Monto}" />
            </DataGridTextColumn.ElementStyle>
          </DataGridTextColumn>
          <DataGridTextColumn Header="Saldo restante"
                              Binding="{Binding SaldoDespues, Converter={StaticResource Money}}" Width="130">
            <DataGridTextColumn.ElementStyle>
              <Style TargetType="TextBlock" BasedOn="{StaticResource Texto.Monto}" />
            </DataGridTextColumn.ElementStyle>
          </DataGridTextColumn>
          <DataGridTemplateColumn Header="Estado" Width="*"
                                  HeaderStyle="{StaticResource Tabla.Encabezado.Izquierda}">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Border Style="{DynamicResource Pill.Semaforo}">
                  <TextBlock Text="{Binding SemaforoTexto}"
                             Style="{DynamicResource Pill.Semaforo.Texto}" />
                </Border>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Border>
  </Grid>
</UserControl>
